ine-height: 16px; color: rgb(69, 69, 69); font-family: NGB; margin-top: -20=
px; text-align: left; margin-left: 10px; background: url("/images/biz/commo=
n/ico/ico-arr-right-gray.png") no-repeat; }

.authorbox { margin-left: 30px; width: 90%; height: 200px; background: rgb(=
