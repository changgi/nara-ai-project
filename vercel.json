{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/server.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/server.py"
    },
    {
      "src": "/health",
      "dest": "api/server.py"
    },
    {
      "src": "/status",
      "dest": "api/server.py"
    },
    {
      "src": "/search",
      "dest": "api/server.py"
    },
    {
      "src": "/pii/(.*)",
      "dest": "api/server.py"
    },
    {
      "src": "/ocr/(.*)",
      "dest": "api/server.py"
    },
    {
      "src": "/docs",
      "dest": "api/server.py"
    },
    {
      "src": "/openapi.json",
      "dest": "api/server.py"
    },
    {
      "src": "/(.*)",
      "dest": "static/$1"
    }
  ],
  "functions": {
    "api/server.py": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
