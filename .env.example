# ═══════════════════════════════════════════════════════════════
# NARA-AI 환경 설정
# 국가 AI 프로젝트 · AI 기반 국가기록물 지능형 검색·분류·활용 체계
# ═══════════════════════════════════════════════════════════════

# ── 프로젝트 ──
PROJECT_NAME=nara-ai
PROJECT_VERSION=1.0.0
NODE_ENV=development

# ── 실행 모드 ──
# auto: GPU 자동 감지 (B200/H100/5090/4060/3060 → 최적 설정)
# gpu:  GPU 강제 사용
# cpu:  CPU 전용 (TF-IDF + BM25, GPU 없이 실행)
NARA_MODE=auto

# ── API 서버 ──
API_HOST=127.0.0.1
API_PORT=8080

# ── AI 모델 (API 키) ──
ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx  # 합성 학습 데이터 생성 시에만

# ── vLLM 추론 서버 ──
VLLM_LLM_ENDPOINT=http://localhost:8000/v1
VLLM_OCR_ENDPOINT=http://localhost:8001/v1
EMBEDDING_ENDPOINT=http://localhost:8002

# ── Milvus 벡터 DB ──
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=nara_records

# ── Cloud Spanner (IARNA) ──
SPANNER_PROJECT_ID=nara-ai-prod
SPANNER_INSTANCE_ID=iarna-instance
SPANNER_DATABASE_ID=iarna-db
# 로컬 에뮬레이터 사용 시:
# SPANNER_EMULATOR_HOST=localhost:9010

# ── RAMP 연동 ──
RAMP_API_URL=https://ramp.archives.go.kr/api
RAMP_API_KEY=

# ── NARA Catalog API ──
NARA_API_KEY=
NARA_API_URL=https://catalog.archives.gov/api/v2

# ── TNA Discovery API ──
TNA_API_KEY=
TNA_API_URL=https://discovery.nationalarchives.gov.uk/API

# ── 학습 설정 ──
WANDB_API_KEY=
WANDB_PROJECT=nara-ai
HF_TOKEN=

# ── 보안 ──
JWT_SECRET=change-this-in-production
ENCRYPTION_KEY=change-this-in-production

# ── 모니터링 ──
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ── 로깅 ──
LOG_LEVEL=info
LOG_DIR=./logs
